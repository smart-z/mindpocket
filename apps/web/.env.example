
# =========================
# MindPocket 环境变量
# 本地开发默认使用 Docker PostgreSQL 18
# 线上部署可继续使用 Neon pooled DATABASE_URL
# =========================

# 1) 数据库（必填）
# 本地示例: postgresql://postgres:postgres@127.0.0.1:5432/mindpocket
# 线上示例: postgresql://<user>:<password>@<neon-pooler-host>/<db>?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/mindpocket

# 2) 应用地址（必填）
# 线上示例: https://your-app.vercel.app
# 本地示例: http://127.0.0.1:3000
NEXT_PUBLIC_APP_URL=

# 3) 认证密钥（必填）
# 建议使用随机长字符串（>=32 位）
# 可用命令生成: openssl rand -base64 32
BETTER_AUTH_SECRET=

# 4) 文件存储（上传功能需要）
# 来源：Vercel Blob
BLOB_READ_WRITE_TOKEN=

# 5) 缓存/队列（可选，AI/缓存相关能力建议配置）
# 来源：Upstash Redis
KV_REST_API_READ_ONLY_TOKEN=
KV_REST_API_TOKEN=
KV_REST_API_URL=
KV_URL=
REDIS_URL=

# 6) 本地测试用（可选）
# 仅在本机做 Chromium 相关测试时需要
CHROMIUM_EXECUTABLE_PATH=

# 7) E2E 测试账号（可选）
# 供 Playwright 登录流程使用
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
